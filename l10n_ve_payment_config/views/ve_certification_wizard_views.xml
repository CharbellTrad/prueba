<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="view_ve_certification_wizard_form" model="ir.ui.view">
        <field name="name">ve.certification.wizard.form</field>
        <field name="model">ve.certification.wizard</field>
        <field name="arch" type="xml">
            <form string="Certificación MegaSoft">
                <header>
                    <button name="action_run_tests" type="object"
                            string="Ejecutar Pruebas" class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_export_excel" type="object"
                            string="Exportar Evidencias" class="btn-secondary"
                            attrs="{'invisible': [('state', '!=', 'done')]}"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,running,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>Wizard de Certificación MegaSoft</h1>
                    </div>

                    <!-- Sesión POS -->
                    <group attrs="{'invisible': [('state', '!=', 'draft')]}">
                        <group string="Sesión POS">
                            <field name="pos_session_id" required="1"/>
                            <field name="active_pos_session_display" readonly="1"
                                   widget="char" nolabel="0"/>
                        </group>
                    </group>

                    <!-- Configuración -->
                    <group attrs="{'invisible': [('state', '!=', 'draft')]}">
                        <group string="Configuración">
                            <field name="gateway_config_id"/>
                            <field name="ci_integrador"/>
                            <field name="telefono_integrador"/>
                            <field name="banco_p2c_id"/>
                            <field name="banco_zelle_id"/>
                        </group>
                    </group>

                    <!-- Resumen -->
                    <group attrs="{'invisible': [('state', '!=', 'done')]}">
                        <group>
                            <field name="total_count"/>
                            <field name="passed_count"/>
                            <field name="failed_count"/>
                        </group>
                        <group>
                            <field name="export_file" filename="export_filename" widget="binary"
                                   attrs="{'invisible': [('export_file', '=', False)]}"/>
                            <field name="export_filename" invisible="1"/>
                        </group>
                    </group>

                    <!-- Resultados -->
                    <notebook attrs="{'invisible': [('state', '!=', 'done')]}">
                        <page string="Resultados" name="results">
                            <field name="result_line_ids" nolabel="1">
                                <tree decoration-success="passed == True"
                                      decoration-danger="passed == False"
                                      decoration-muted="requires_manual == True and passed == True">
                                    <field name="test_id" string="#"/>
                                    <field name="test_name"/>
                                    <field name="service_code"/>
                                    <field name="amount_str"/>
                                    <field name="codigo"/>
                                    <field name="referencia"/>
                                    <field name="passed" widget="boolean"/>
                                    <field name="requires_manual"/>
                                    <field name="error_detail"/>
                                    <field name="qr_url" widget="url"
                                           attrs="{'invisible': [('qr_url', '=', False)]}"/>
                                </tree>
                                <form>
                                    <group>
                                        <field name="test_id"/>
                                        <field name="test_name"/>
                                        <field name="service_code"/>
                                        <field name="amount_str"/>
                                        <field name="control"/>
                                        <field name="referencia"/>
                                        <field name="codigo"/>
                                        <field name="descripcion"/>
                                        <field name="passed"/>
                                        <field name="requires_manual"/>
                                        <field name="error_detail"/>
                                        <field name="qr_url" widget="url"/>
                                        <field name="log_id"/>
                                    </group>
                                    <group string="Voucher" attrs="{'invisible': [('voucher', '=', False)]}">
                                        <field name="voucher" nolabel="1"
                                               style="font-family: 'Courier New', monospace; white-space: pre-wrap;"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>

                    <!-- Progreso -->
                    <div class="text-center" attrs="{'invisible': [('state', '!=', 'running')]}">
                        <i class="fa fa-spinner fa-spin fa-3x text-primary"/>
                        <p class="mt-3">Ejecutando pruebas de certificación...</p>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ve_certification_wizard" model="ir.actions.act_window">
        <field name="name">Certificación MegaSoft</field>
        <field name="res_model">ve.certification.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu (bajo Contabilidad > Pasarela de Pagos) -->
    <menuitem id="menu_ve_certification_wizard"
              name="Certificación MegaSoft"
              parent="l10n_ve_payment_config.menu_ve_payment_root"
              action="action_ve_certification_wizard"
              groups="account.group_account_manager"
              sequence="40"/>

</odoo>
