<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- VISTA FORMULARIO - Log de Transacciones -->
    <record id="view_ve_bank_transaction_log_form" model="ir.ui.view">
        <field name="name">ve.bank.transaction.log.form</field>
        <field name="model">ve.bank.transaction.log</field>
        <field name="arch" type="xml">
            <form string="Transacción Pasarela" create="0">
                <sheet>
                    <widget name="web_ribbon" title="Aprobada"
                            attrs="{'invisible': [('approved', '=', False)]}"/>
                    <widget name="web_ribbon" title="Rechazada" bg_color="bg-danger"
                            attrs="{'invisible': [('approved', '=', True)]}"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Identificación">
                            <field name="service_code"/>
                            <field name="gateway_config_id"/>
                            <field name="factura"
                                   attrs="{'invisible': [('factura', 'in', [False, ''])]}"/>
                            <field name="amount"
                                   attrs="{'invisible': [('amount', '=', 0)]}"/>
                            <field name="control"
                                   attrs="{'invisible': [('control', 'in', [False, ''])]}"/>
                            <field name="pos_session_id"
                                   attrs="{'invisible': [('pos_session_id', '=', False)]}"/>
                            <field name="payment_transaction_id"
                                   attrs="{'invisible': [('payment_transaction_id', '=', False)]}"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Respuesta">
                            <field name="approved"/>
                            <field name="codigo"
                                   attrs="{'invisible': [('codigo', 'in', [False, ''])]}"/>
                            <field name="descripcion"
                                   attrs="{'invisible': [('descripcion', 'in', [False, ''])]}"/>
                            <field name="referencia"
                                   attrs="{'invisible': [('referencia', 'in', [False, ''])]}"/>
                            <field name="seqnum"
                                   attrs="{'invisible': [('seqnum', 'in', [False, ''])]}"/>
                            <field name="authid"
                                   attrs="{'invisible': [('authid', 'in', [False, ''])]}"/>
                            <field name="authname"
                                   attrs="{'invisible': [('authname', 'in', [False, ''])]}"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Voucher" name="voucher">
                            <field name="voucher" readonly="1"
                                   widget="text"
                                   placeholder="Sin voucher disponible"
                                   style="font-family: monospace; white-space: pre;"/>
                        </page>
                        <page string="Solicitud Enviada" name="request"
                              groups="base.group_system">
                            <field name="request_data" readonly="1"
                                   widget="text"
                                   placeholder="Sin datos de solicitud disponibles"
                                   style="font-family: monospace; white-space: pre-wrap; word-break: break-all;"/>
                        </page>
                        <page string="XML Respuesta" name="raw_xml"
                              groups="base.group_system">
                            <field name="response_raw" readonly="1"
                                   widget="text"
                                   placeholder="Sin XML disponible"
                                   style="font-family: monospace; white-space: pre-wrap; word-break: break-all;"/>
                        </page>
                        <page string="Detalles Transacci&#243;n" name="details">
                            <group>
                                <group string="Terminal y Lote"
                                       attrs="{'invisible': ['&amp;', '&amp;', '&amp;', '&amp;', ('terminal', 'in', [False, '']), ('lote', 'in', [False, '']), ('afiliacion', 'in', [False, '']), ('vtid', 'in', [False, '']), ('tipotrx', 'in', [False, ''])]}">
                                    <field name="terminal"/>
                                    <field name="lote"
                                           attrs="{'invisible': [('lote', 'in', [False, ''])]}"/>
                                    <field name="afiliacion" string="Afiliaci&#243;n"
                                           attrs="{'invisible': [('afiliacion', 'in', [False, ''])]}"/>
                                    <field name="vtid"
                                           attrs="{'invisible': [('vtid', 'in', [False, ''])]}"/>
                                    <field name="tipotrx"
                                           attrs="{'invisible': ['|', ('tipotrx', 'in', [False, '']), ('service_code', 'in', ['C2P', 'P2C', 'VUELTO', 'ZELLE', 'CRYPTO'])]}"/>
                                </group>
                                <group string="Moneda"
                                       attrs="{'invisible': ['&amp;', '&amp;', ('monto_divisa', 'in', [False, '']), ('moneda_inicio', 'in', [False, '']), ('moneda_fin', 'in', [False, ''])]}">
                                    <field name="monto_divisa"/>
                                    <field name="moneda_inicio"
                                           attrs="{'invisible': [('moneda_inicio', 'in', [False, ''])]}"/>
                                    <field name="moneda_fin"
                                           attrs="{'invisible': [('moneda_fin', 'in', [False, ''])]}"/>
                                </group>
                            </group>
                            <group>
                                <group string="Datos Bancarios"
                                       attrs="{'invisible': ['&amp;', '&amp;', '&amp;', '&amp;', '&amp;', '&amp;', ('tarjeta_enmascarada', 'in', [False, '']), ('banco_emisor', 'in', [False, '']), ('banco_adquiriente', 'in', [False, '']), ('telefono_emisor', 'in', [False, '']), ('telefono_adquiriente', 'in', [False, '']), ('cuenta_cliente', 'in', [False, '']), ('cuenta_comercio', 'in', [False, ''])]}">
                                    <field name="tarjeta_enmascarada"
                                           attrs="{'invisible': [('tarjeta_enmascarada', 'in', [False, ''])]}"/>
                                    <field name="banco_emisor"
                                           attrs="{'invisible': [('banco_emisor', 'in', [False, ''])]}"/>
                                    <field name="banco_adquiriente"
                                           attrs="{'invisible': [('banco_adquiriente', 'in', [False, ''])]}"/>
                                    <field name="telefono_emisor"
                                           attrs="{'invisible': [('telefono_emisor', 'in', [False, ''])]}"/>
                                    <field name="telefono_adquiriente"
                                           attrs="{'invisible': [('telefono_adquiriente', 'in', [False, ''])]}"/>
                                    <field name="cuenta_cliente"
                                           attrs="{'invisible': [('cuenta_cliente', 'in', [False, ''])]}"/>
                                    <field name="cuenta_comercio"
                                           attrs="{'invisible': [('cuenta_comercio', 'in', [False, ''])]}"/>
                                </group>
                                <group string="Criptomonedas"
                                       attrs="{'invisible': ['&amp;', '&amp;', ('monto_crypto', 'in', [False, '']), ('nombre_moneda', 'in', [False, '']), ('tipo_moneda_crypto', 'in', [False, ''])]}">
                                    <field name="monto_crypto"/>
                                    <field name="nombre_moneda"
                                           attrs="{'invisible': [('nombre_moneda', 'in', [False, ''])]}"/>
                                    <field name="tipo_moneda_crypto"
                                           attrs="{'invisible': [('tipo_moneda_crypto', 'in', [False, ''])]}"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- VISTA ARBOL -->
    <record id="view_ve_bank_transaction_log_tree" model="ir.ui.view">
        <field name="name">ve.bank.transaction.log.tree</field>
        <field name="model">ve.bank.transaction.log</field>
        <field name="arch" type="xml">
            <tree string="Transacciones Pasarela"
                  decoration-success="approved == True"
                  decoration-danger="approved == False"
                  create="0">
                <field name="create_date" string="Fecha"/>
                <field name="service_code" string="Tipo"/>
                <field name="factura"/>
                <field name="control" optional="hide"/>
                <field name="referencia" string="Ref. Banco"/>
                <field name="amount" string="Monto"/>
                <field name="codigo" string="Código"/>
                <field name="approved"/>
                <field name="pos_session_id" string="Sesión POS" optional="show"/>
            </tree>
        </field>
    </record>

    <!-- FILTROS -->
    <record id="view_ve_bank_transaction_log_search" model="ir.ui.view">
        <field name="name">ve.bank.transaction.log.search</field>
        <field name="model">ve.bank.transaction.log</field>
        <field name="arch" type="xml">
            <search string="Buscar Transacciones">
                <field name="name"/>
                <field name="referencia"/>
                <field name="control"/>
                <field name="factura"/>
                <field name="service_code"/>
                <filter string="Aprobadas" name="approved"
                        domain="[('approved', '=', True)]"/>
                <filter string="Rechazadas" name="rejected"
                        domain="[('approved', '=', False)]"/>
                <separator/>
                <filter string="Hoy" name="today"
                        domain="[('create_date', '&gt;=', (context_today()).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter string="C2P" name="filter_c2p"
                        domain="[('service_code', '=', 'C2P')]"/>
                <filter string="P2C" name="filter_p2c"
                        domain="[('service_code', '=', 'P2C')]"/>
                <filter string="Zelle" name="filter_zelle"
                        domain="[('service_code', '=', 'ZELLE')]"/>
                <filter string="Tarjeta" name="filter_tarjeta"
                        domain="[('service_code', '=', 'TARJETA')]"/>
                <filter string="Crypto" name="filter_crypto"
                        domain="[('service_code', '=', 'CRYPTO')]"/>
                <filter string="Transferencia / Crédito Inmediato" name="filter_transferencia"
                        domain="[('service_code', '=', 'TRANSFERENCIA')]"/>
                <filter string="Vuelto" name="filter_vuelto"
                        domain="[('service_code', '=', 'VUELTO')]"/>
                <separator/>
                <filter string="Sesión POS" name="filter_pos"
                        domain="[('pos_session_id', '!=', False)]"/>
                <filter string="E-commerce" name="filter_ecommerce"
                        domain="[('payment_transaction_id', '!=', False)]"/>
                <group string="Agrupar por">
                    <filter string="Tipo Servicio" name="group_service"
                            context="{'group_by': 'service_code'}"/>
                    <filter string="Aprobada" name="group_approved"
                            context="{'group_by': 'approved'}"/>
                    <filter string="Fecha" name="group_date"
                            context="{'group_by': 'create_date:day'}"/>
                    <filter string="Sesión POS" name="group_pos"
                            context="{'group_by': 'pos_session_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACCION -->
    <record id="action_ve_bank_transaction_log" model="ir.actions.act_window">
        <field name="name">Logs de Transacciones</field>
        <field name="res_model">ve.bank.transaction.log</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_approved': 1}</field>
    </record>
</odoo>
