<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FORMULARIO SERVICIO -->
    <record id="view_ve_payment_service_form" model="ir.ui.view">
        <field name="name">ve.payment.service.form</field>
        <field name="model">ve.payment.service</field>
        <field name="arch" type="xml">
            <form string="Servicio de Pago">
                <sheet>
                    <div class="oe_title">
                        <label for="display_name"/>
                        <h1><field name="display_name"/></h1>
                    </div>
                    <group>
                        <group string="Configuración">
                            <field name="gateway_config_id"/>
                            <field name="service_type_id"
                                   options="{'no_create': True, 'no_edit': True}"/>
                            <field name="active" string="Habilitado"/>
                            <field name="service_code" invisible="1"/>
                        </group>
                        <group string="Resumen">
                            <field name="bank_count" string="Bancos habilitados"/>
                        </group>
                    </group>

                    <group string="Instrucciones para el Cajero">
                        <field name="notes" nolabel="1" colspan="2"
                               placeholder="Ej: Solicite al cliente la referencia de 8 dígitos que le envió el banco..."/>
                    </group>

                    <separator string="Bancos / Plataformas Habilitadas"
                               attrs="{'invisible': [('service_code', 'not in', ['p2c','transferencia','zelle'])]}"/>
                    <field name="bank_ids"
                           attrs="{'invisible': [('service_code', 'not in', ['p2c','transferencia','zelle'])]}">
                        <tree editable="bottom" decoration-muted="active == False">
                            <field name="sequence" widget="handle"/>
                            <field name="service_code" invisible="1"/>
                            <field name="bank_id" string="Banco / Plataforma"
                                   options="{'no_create': True}"
                                   context="{'service_code': parent.service_code}"
                                   domain="[('bank_type', '=', 'zelle' if context.get('service_code') == 'zelle' else 've')]"/>
                            <field name="account_number" string="Cuenta Destino"
                                   attrs="{'column_invisible': [('parent.service_code', '!=', 'transferencia')]}"/>
                            <field name="phone_number" string="Teléfono Comercio"
                                   attrs="{'column_invisible': [('parent.service_code', '!=', 'p2c')]}"/>

                            <field name="notes" string="Nota" optional="hide"/>
                            <field name="is_default" string="Principal" widget="boolean_toggle"/>
                            <field name="active" string="Activo" widget="boolean_toggle"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ARBOL SERVICIOS -->
    <record id="view_ve_payment_service_tree" model="ir.ui.view">
        <field name="name">ve.payment.service.tree</field>
        <field name="model">ve.payment.service</field>
        <field name="arch" type="xml">
            <tree string="Servicios de Pago" decoration-muted="active == False">
                <field name="sequence" widget="handle"/>
                <field name="gateway_config_id" string="Configuración"/>
                <field name="service_type_id" string="Tipo de Servicio"/>
                <field name="bank_count" string="Bancos"/>
                <field name="notes_short" string="Instrucciones" optional="show"/>
                <field name="active" string="Habilitado" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="action_ve_payment_service" model="ir.actions.act_window">
        <field name="name">Servicios de Pago</field>
        <field name="res_model">ve.payment.service</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
