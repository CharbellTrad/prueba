<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_config_form_ve_payment" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.ve_payment</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <div id="pos_payment_section" position="after">
                <h2>Verificación de Pagos Bancarios</h2>
                <div class="row mt16 o_settings_container" id="ve_payment_section">
                    <!-- Activar pasarela -->
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane">
                            <field name="ve_payment_enabled"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="ve_payment_enabled" string="Activar Pasarela de Pagos"/>
                            <div class="text-muted">
                                Muestra el botón de pagos bancarios en la pantalla de cobro
                            </div>
                            <div class="content-group mt8"
                                 attrs="{'invisible': [('ve_payment_enabled','=',False)]}">
                                <div class="row mt8">
                                    <label for="ve_payment_config_id" string="Configuración"
                                           class="col-lg-4 o_light_label"/>
                                    <field name="ve_payment_config_id"
                                           domain="[('active','=',True)]"
                                           placeholder="Seleccione la pasarela..."/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Servicios habilitados -->
                    <div class="col-12 col-lg-6 o_setting_box"
                         attrs="{'invisible': [('ve_payment_enabled','=',False)]}">
                        <div class="o_setting_right_pane">
                            <span class="o_form_label">Servicios habilitados en el POS</span>
                            <div class="text-muted">
                                Solo se muestran los servicios activos de la afiliación seleccionada.
                            </div>
                            <div class="content-group mt8"
                                 attrs="{'invisible': [('ve_payment_config_id','=',False)]}">
                                <field name="ve_pos_enabled_services"
                                       widget="many2many_checkboxes"
                                       domain="[('gateway_config_id', '=', ve_payment_config_id), ('active', '=', True), ('service_code', '!=', 'tarjeta')]"/>
                            </div>
                            <div class="content-group mt8 text-muted"
                                 attrs="{'invisible': [('ve_payment_config_id','!=',False)]}">
                                <em>Seleccione primero una configuración de pasarela.</em>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </field>
    </record>
</odoo>
