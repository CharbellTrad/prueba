<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="VEPaymentScreen" t-inherit="point_of_sale.PaymentScreen" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('payment-controls')]" position="inside">
            <t t-if="vePaymentEnabled">
                <div class="button js_ve_payment" t-on-click="openVEPaymentPopup">
                    <i class="fa fa-university"/> Pagos Bancarios
                </div>
            </t>
        </xpath>
    </t>

</templates>
