<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_direct_print" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pos_direct_print</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pos_connected_devices_section']" position="after">
                <block title="[POS] Print Agent" id="pos_direct_print_section">
                    <setting string="Direct Ticket Print"
                             help="Imprime el ticket directamente al validar la orden, sin diálogo de impresión"
                             id="direct_print_setting">
                        <field name="pos_direct_print_enabled"/>
                        <div class="content-group mt16" invisible="not pos_direct_print_enabled">
                            <div class="row">
                                <label string="Service URL" for="pos_direct_print_url" class="col-lg-3 o_light_label"/>
                                <field name="pos_direct_print_url" placeholder="http://localhost:7865"/>
                            </div>
                            <p class="text-muted small mt8 mb0">
                                Las impresoras se configuran desde el dashboard del servicio local.
                            </p>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
