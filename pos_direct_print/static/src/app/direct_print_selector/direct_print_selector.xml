<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pos_direct_print.DirectPrintSelector">
        <div class="direct-print-bar">

            <!-- Status dot + label (click to refresh) -->
            <div class="dp-status"
                 t-att-class="statusDot.cls"
                 t-att-title="statusDot.title"
                 t-on-click="onRefreshStatus">
                <span class="dp-dot-circle"/>
                <span class="dp-label">
                    <t t-if="state.loading">Verificando...</t>
                    <t t-elif="state.serviceOnline and state.printers.length > 0">Conectado</t>
                    <t t-elif="state.serviceOnline">Sin impresoras</t>
                    <t t-else="">Sin servicio</t>
                </span>
            </div>

            <!-- Printer select -->
            <select class="dp-select"
                    t-on-change="onChangePrinter"
                    t-att-disabled="state.printers.length === 0 or state.loading">
                <option t-if="state.printers.length === 0" value="" disabled="true" selected="true">
                    <t t-if="state.loading">Cargando...</t>
                    <t t-elif="!state.serviceOnline">Servicio desconectado</t>
                    <t t-else="">Sin impresoras</t>
                </option>
                <t t-foreach="state.printers" t-as="printer" t-key="printer.alias">
                    <option t-att-value="printer.alias"
                            t-att-selected="printer.alias === selectedPrinterAlias">
                        <t t-esc="printer.alias"/>
                        <t t-if="printer.is_default"> ✓</t>
                    </option>
                </t>
            </select>

            <!-- Toggle button — same visual style as Validate button -->
            <button t-att-class="'btn ' + (isDirectPrintEnabled ? 'btn-primary' : 'btn-secondary') + ' dp-toggle' + (!canEnableDirectPrint ? ' dp-toggle--locked' : '')"
                    t-att-disabled="!canEnableDirectPrint and !isDirectPrintEnabled"
                    t-on-click="onToggleDirectPrint"
                    t-att-title="!canEnableDirectPrint ? 'Requiere servicio activo con impresoras disponibles' : (isDirectPrintEnabled ? 'Desactivar impresión directa' : 'Activar impresión directa')">
                <i class="fa fa-print me-1"/>
                <t t-if="isDirectPrintEnabled">Directa</t>
                <t t-else="">Manual</t>
            </button>

            <!-- Refresh button — same style as Validate button -->
            <button class="btn btn-primary dp-refresh"
                    t-att-class="{ 'dp-refresh--spinning': state.loading }"
                    t-on-click="onRefreshStatus"
                    t-att-disabled="state.loading"
                    title="Verificar estado del servicio">
                <i class="fa fa-refresh"/>
            </button>

        </div>
    </t>

</templates>
