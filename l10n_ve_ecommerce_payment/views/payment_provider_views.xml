<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista heredada del formulario de payment.provider -->
    <record id="view_payment_provider_form_ve_gateway" model="ir.ui.view">
        <field name="name">payment.provider.form.inherit.ve_gateway</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <group name="provider_credentials" position="inside">
                <group string="Pasarela Bancaria VE"
                       attrs="{'invisible': [('code', '!=', 've_payment_gateway')]}">
                    <field name="ve_gateway_config_id"
                           domain="[('active', '=', True)]"
                           placeholder="Seleccione configuración..."
                           attrs="{'required': [('code', '=', 've_payment_gateway'), ('state', '=', 'enabled')]}"/>
                    <field name="ve_gateway_mode_card"/>
                    <field name="ve_gateway_currency"/>
                </group>
            </group>
        </field>
    </record>
</odoo>
