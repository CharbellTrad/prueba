<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="account_internal_consumption.PartnerList" t-inherit="point_of_sale.PartnerList" t-inherit-mode="extension">
        <xpath expr="//Input" position="after">
            <button class="btn btn-lg ms-2"
                    t-att-class="state.filterConsumption ? '' : 'btn-secondary'"
                    t-att-style="state.filterConsumption ? 'background-color: #714B67; border-color: #714B67; color: white;' : ''"
                    t-on-click="toggleConsumptionFilter"
                    t-att-title="state.filterConsumption ? 'Mostrando solo consumo interno (click para quitar filtro)' : 'Filtrar por consumo interno'">
                <i class="fa fa-users"/>
            </button>
            <button t-if="isBarcodeScannerSupported() and !pos.config.module_pos_restaurant" 
                    class="btn btn-lg ms-2" 
                    t-att-class="state.scanning ? 'btn-danger' : 'btn-secondary'" 
                    t-on-click="toggleScanning">
                <i class="fa fa-barcode fs-2"/>
            </button>
        </xpath>
        <xpath expr="//div[hasclass('h-100')]" position="attributes">
            <attribute name="class">h-100 position-relative</attribute>
        </xpath>
        <xpath expr="//div[hasclass('h-100')]/*[1]" position="before">
            <BarcodeVideoScanner t-if="state.scanning" t-props="barcodeVideoScannerProps" />
        </xpath>
    </t>

    <t t-name="account_internal_consumption.PartnerLine" t-inherit="point_of_sale.PartnerLine" t-inherit-mode="extension">
        <xpath expr="//td[hasclass('partner-line-balance')]" position="inside">
            <div t-if="props.partner.is_internal_consumption or props.partner.employee" class="pos-right-align mt-1" style="font-size: 0.82rem; line-height: 1.4; white-space: nowrap;">
                <t t-if="props.partner.is_internal_consumption">
                    <t t-set="act" t-value="props.partner.allowed_consumption_types || 'both'"/>
                    <span t-if="(act === 'both' or act === 'personal_only') and props.partner.is_unlimited_personal and (act !== 'both' or props.partner.is_unlimited_attention)" class="text-end" style="font-size:0.72rem; line-height:1.5; white-space:nowrap;">
                        <div class="text-muted fw-semibold">Consumos Internos:</div>
                        <div class="fw-semibold" style="color: #714B67;">Sin límite</div>
                    </span>
                    <span t-elif="act === 'attention_only' and props.partner.is_unlimited_attention" class="text-end" style="font-size:0.72rem; line-height:1.5; white-space:nowrap;">
                        <div class="text-muted fw-semibold">Consumos Internos:</div>
                        <div class="fw-semibold" style="color: #714B67;">Sin límite</div>
                    </span>
                    <t t-elif="props.partner.available_personal_info !== undefined or props.partner.available_attention_info !== undefined">
                        <div style="font-size:0.72rem; line-height:1.5; white-space:nowrap;" class="text-end">
                            <div class="text-muted fw-semibold">Consumos Internos:</div>
                            <div t-if="act !== 'attention_only'">
                                P:
                                <t t-if="props.partner.is_unlimited_personal"><strong style="color: #714B67;">Sin límite</strong></t>
                                <t t-else="">
                                    <strong t-att-class="(props.partner.available_personal_info || 0) &lt;= 0 ? 'text-danger' : ''">
                                        <t t-esc="env.utils.formatCurrency(props.partner.available_personal_info || 0)"/>
                                    </strong>
                                </t>
                            </div>
                            <div t-if="act !== 'personal_only'">
                                A:
                                <t t-if="props.partner.is_unlimited_attention"><strong style="color: #714B67;">Sin límite</strong></t>
                                <t t-else="">
                                    <strong t-att-class="(props.partner.available_attention_info || 0) &lt;= 0 ? 'text-danger' : ''">
                                        <t t-esc="env.utils.formatCurrency(props.partner.available_attention_info || 0)"/>
                                    </strong>
                                </t>
                            </div>
                        </div>
                    </t>
                </t>
                <span t-elif="!props.partner.is_internal_consumption and props.partner.employee" class="text-end" style="font-size:0.72rem; line-height:1.5; white-space:nowrap;">
                    <div class="text-muted fw-semibold">Consumos Internos:</div>
                    <div class="text-muted fst-italic">No configurado</div>
                </span>
            </div>
        </xpath>
    </t>
</templates>
