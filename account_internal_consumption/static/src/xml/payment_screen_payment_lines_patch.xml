<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-inherit="point_of_sale.PaymentScreenPaymentLines" t-inherit-mode="extension">
        
        <!-- Cuando la línea está seleccionada (expandida) -->
        <xpath expr="//span[hasclass('payment-name')]/t[@t-esc='line.payment_method_id.name']" position="replace">
            <div class="d-flex flex-column w-100">
                <span class="fw-bold"><t t-esc="line.consumption_payment_name"/></span>
                <t t-set="stats" t-value="line.internal_consumption_stats"/>
                <t t-if="stats.is_active">
                    <div class="d-flex flex-column mt-1">

                        <t t-if="stats.status === 'all_disabled'">
                            <span class="text-danger fw-bold" style="font-size:0.85rem;">
                                <i class="fa fa-ban me-1"/>Todos los tipos de consumos deshabilitados
                            </span>
                        </t>
                        <t t-elif="stats.status === 'disabled'">
                            <span class="text-danger fw-bold" style="font-size:0.85rem;">
                                <i class="fa fa-ban me-1"/>Consumo interno desactivado
                            </span>
                        </t>
                        <t t-elif="stats.status === 'not_configured'">
                            <span class="text-warning fw-bold" style="font-size:0.85rem;">
                                <i class="fa fa-exclamation-triangle me-1"/>Consumo interno no configurado
                            </span>
                        </t>
                        <t t-elif="stats.status === 'no_type'">
                        </t>
                        <t t-elif="stats.status === 'loading'">
                            <span class="text-muted small">
                                <i class="fa fa-spinner fa-spin"/> Cargando...
                            </span>
                        </t>
                        <t t-elif="stats.status === 'unlimited'">
                            <div class="ic-stats-bar">
                                <span class="ic-stat-item">
                                    <span class="ic-stat-label"><t t-esc="stats.consumption_type === 'personal' ? 'Personal' : 'Atención'"/>:</span>
                                    <span class="ic-stat-val text-success">Sin Límite</span>
                                </span>
                                <span class="ic-stat-sep">·</span>
                                <span class="ic-stat-item">
                                    <span class="ic-stat-label">Consumo:</span>
                                    <span class="ic-stat-val text-success"><t t-esc="env.utils.formatCurrency(stats.current_payment)"/></span>
                                </span>
                            </div>
                        </t>
                        <t t-elif="stats.status === 'ok'">
                            <div class="ic-stats-bar">
                                <span class="ic-stat-item">
                                    <span class="ic-stat-label">Disp:</span>
                                    <span t-attf-class="ic-stat-val {{ stats.available_previous &lt;= 0 ? 'text-danger' : 'text-success' }}">
                                        <t t-esc="env.utils.formatCurrency(stats.available_previous)"/>
                                    </span>
                                </span>
                                <span class="ic-stat-sep">·</span>
                                <span class="ic-stat-item">
                                    <span class="ic-stat-label">Consumo:</span>
                                    <span t-attf-class="ic-stat-val {{ stats.current_payment &gt; stats.available_previous ? 'text-danger' : '' }}">
                                        <t t-esc="env.utils.formatCurrency(stats.current_payment)"/>
                                    </span>
                                </span>
                                <span class="ic-stat-sep">·</span>
                                <span class="ic-stat-item">
                                    <span class="ic-stat-label">Final:</span>
                                    <span t-attf-class="ic-stat-val fw-bold {{ stats.available_final &lt;= 0 ? 'text-danger' : 'text-success' }}">
                                        <t t-esc="env.utils.formatCurrency(stats.available_final)"/>
                                    </span>
                                </span>
                            </div>
                        </t>

                        <!-- Full-width toggle selector at the bottom (hidden when only one type) -->
                        <t t-if="stats.status !== 'all_disabled' and stats.status !== 'disabled' and stats.status !== 'not_configured' and line._shouldShowToggle">
                            <div class="ic-toggle" t-att-data-active="line.consumption_type || 'none'">
                                <div class="ic-toggle__track">
                                    <div t-attf-class="ic-toggle__slider {{ !line.consumption_type ? 'ic-toggle__slider--hidden' : '' }}"
                                         t-att-data-pos="line.consumption_type || 'none'"/>
                                    <div t-attf-class="ic-toggle__option {{ line.consumption_type === 'personal' ? 'ic-toggle__option--active' : '' }}"
                                         t-on-click="() =&gt; { line.setConsumptionType('personal'); this.render(true); }">
                                        <i class="fa fa-user ic-toggle__icon"/>
                                        <span>Personal</span>
                                    </div>
                                    <div t-attf-class="ic-toggle__option {{ line.consumption_type === 'attention' ? 'ic-toggle__option--active' : '' }}"
                                         t-on-click="() =&gt; { line.setConsumptionType('attention'); this.render(true); }">
                                        <i class="fa fa-handshake-o ic-toggle__icon"/>
                                        <span>Atención</span>
                                    </div>
                                </div>
                            </div>
                        </t>

                    </div>
                </t>
            </div>
        </xpath>

        <!-- Cuando la línea NO está seleccionada (colapsada) -->
        <xpath expr="//div[hasclass('payment-infos')]//t[@t-esc='line.payment_method_id?.name']" position="replace">
             <div class="d-flex flex-column">
                <span class="fw-bold"><t t-esc="line.consumption_payment_name"/></span>
                <t t-set="stats" t-value="line.internal_consumption_stats"/>
                <t t-if="stats.is_active">
                    <div class="mt-1" style="font-size: 0.78rem;">
                        <t t-if="stats.status === 'all_disabled'">
                            <span class="text-danger fw-semibold">
                                <i class="fa fa-ban me-1"/>Consumos deshabilitados
                            </span>
                        </t>
                        <t t-elif="stats.status === 'disabled'">
                            <span class="text-danger fw-semibold">
                                <i class="fa fa-ban me-1"/>Desactivado
                            </span>
                        </t>
                        <t t-elif="stats.status === 'not_configured'">
                            <span class="text-warning fw-semibold">
                                <i class="fa fa-exclamation-triangle me-1"/>No configurado
                            </span>
                        </t>
                        <t t-elif="stats.status === 'no_type'">
                            <span class="text-warning fw-semibold">Seleccionar tipo</span>
                        </t>
                        <t t-elif="stats.status === 'unlimited'">
                            <span class="fw-semibold" style="color: #714B67;">Sin Límite</span>
                        </t>
                        <t t-elif="stats.status === 'ok'">
                            <span class="fw-semibold" style="color: #64748b;">Disponible Final: </span>
                            <span t-attf-class="fw-bold {{ stats.available_final &lt;= 0 ? 'text-danger' : '' }}" t-att-style="stats.available_final > 0 ? 'color: #714B67;' : ''">
                                <t t-esc="env.utils.formatCurrency(stats.available_final)"/>
                            </span>
                        </t>
                    </div>
                </t>
            </div>
        </xpath>
    </t>
</templates>