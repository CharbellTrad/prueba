<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_payment_method_form_consumption" model="ir.ui.view">
        <field name="name">pos.payment.method.form.consumption</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
        <field name="arch" type="xml">
            <!-- Añade el campo Consumo Interno después de Split Transactions -->
            <xpath expr="//field[@name='split_transactions']" position="after">
                <field name="is_internal_consumption"/>
            </xpath>
            <!-- Hace el campo Diario readonly y vacío cuando Consumo Interno está activo -->
            <xpath expr="//field[@name='journal_id']" position="attributes">
                <attribute name="readonly">is_internal_consumption</attribute>
            </xpath>
        </field>
    </record>
</odoo>
