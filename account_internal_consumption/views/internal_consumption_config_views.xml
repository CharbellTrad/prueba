<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- VISTA FORMULARIO -->
    <record id="view_internal_consumption_config_form" model="ir.ui.view">
        <field name="name">internal.consumption.config.form</field>
        <field name="model">internal.consumption.config</field>
        <field name="arch" type="xml">
            <form string="Configuración de Consumo Interno">
                <header/>
                <sheet>
                    <!-- Botones inteligentes (stat buttons) -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_audits"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-clipboard">
                            <field name="audit_count"
                                   widget="statinfo"
                                   string="Consumo Emitidos"/>
                        </button>
                    </div>
                    <widget name="web_ribbon"
                            title="Archivado"
                            bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre de la configuración..."
                                   readonly="audit_count &gt; 0"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Clasificación">
                            <field name="belongs_to_odoo"
                                   readonly="account_id or audit_count &gt; 0"/>
                            <field name="department_id"
                                   invisible="not belongs_to_odoo"
                                   required="belongs_to_odoo"
                                   readonly="audit_count &gt; 0"/>
                            <field name="partner_id"
                                   invisible="belongs_to_odoo"
                                   required="not belongs_to_odoo"
                                   readonly="audit_count &gt; 0"/>
                            <field name="company_id"
                                   invisible="not belongs_to_odoo"
                                   readonly="1"/>
                        </group>
                        <group string="Configuración">
                            <field name="currency_id" readonly="1"/>
                            <field name="allowed_consumption_types"
                                   readonly="audit_count &gt; 0"/>
                            <field name="account_code"/>
                            <field name="account_id" readonly="1" force_save="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Límite Personal"
                               invisible="allowed_consumption_types == 'attention_only'">
                            <field name="personal_limit" string="Límite Consumible"/>
                            <field name="available_personal" readonly="1" invisible="not personal_limit" string="Disponible General"/>
                            <field name="consumed_personal" readonly="1" string="Consumido General"/>
                        </group>
                        <group string="Límite Personal"
                               invisible="allowed_consumption_types != 'attention_only'">
                            <field name="not_configured_personal_label" string="Límite Consumible" readonly="1"/>
                        </group>
                        <group string="Límite Atención"
                               invisible="allowed_consumption_types == 'personal_only'">
                            <field name="attention_limit" string="Límite Consumible"/>
                            <field name="available_attention" readonly="1" invisible="not attention_limit" string="Disponible General"/>
                            <field name="consumed_attention" readonly="1" string="Consumido General"/>
                        </group>
                        <group string="Límite Atención"
                               invisible="allowed_consumption_types != 'personal_only'">
                            <field name="not_configured_attention_label" string="Límite Consumible" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Período Vigente">
                            <label for="period_value" string="Período de Reinicio"/>
                            <div class="d-flex gap-2 align-items-center">
                                <field name="period_value" class="oe_inline" readonly="audit_count &gt; 0"/>
                                <field name="period_type" class="oe_inline" readonly="audit_count &gt; 0"/>
                            </div>
                            <field name="period_start" readonly="1"/>
                            <field name="period_end" readonly="1"/>
                        </group>
                    </group>
                    <field name="active" invisible="1"/>

                    <!-- Pestañas -->
                    <notebook>
                        <!-- Pestaña Empleados (solo para configs de tipo Departamento) -->
                        <page string="Empleados"
                              name="employees_tab"
                              invisible="not belongs_to_odoo">
                            <field name="employee_ids"
                                   context="{'default_department_id': department_id}" create="0" delete="0" class="ic_no_add_line">
                                <list string="Empleados del Departamento" editable="bottom" create="0" delete="0">
                                    <field name="employee_link_id" string="Empleado" readonly="1"/>
                                    <field name="work_contact_id" string="Contacto" optional="hide" readonly="1"/>
                                    <field name="job_id" optional="hide" readonly="1"/>
                                    <field name="allow_personal_consumption" width="175px" readonly="0"
                                           string="Permitir Cons. Personales"
                                           column_invisible="parent.allowed_consumption_types == 'attention_only'"/>
                                    <field name="allow_attention_consumption" width="165px" readonly="0"
                                           string="Permitir Cons. Atención"
                                           column_invisible="parent.allowed_consumption_types == 'personal_only'"/>
                                    <field name="consumption_currency_id" column_invisible="1"/>
                                    <field name="individual_consumed_personal" width="130px" string="Cons. Personal"
                                           widget="monetary" readonly="1"/>
                                    <field name="individual_consumed_attention" width="130px" string="Cons. Atención"
                                           widget="monetary" readonly="1"/>
                                    <field name="available_personal_info" width="115px" string="Disp. Personal"
                                           widget="monetary" readonly="1"
                                           column_invisible="parent.personal_limit == 0"/>
                                    <field name="available_attention_info" width="115px" string="Disp. Atención"
                                           widget="monetary" readonly="1"
                                           column_invisible="parent.attention_limit == 0"/>
                                    <field name="period_end_info" string="Fin Período"
                                           optional="hide" readonly="1"/>
                                </list>
                            </field>
                        </page>

                        <!-- Pestaña Contactos (solo para configs de tipo Contacto Externo) -->
                        <page string="Contactos"
                              name="contacts_tab"
                              invisible="belongs_to_odoo">
                            <field name="contact_ids" create="0" delete="0" class="ic_no_add_line">
                                <list string="Contactos Relacionados" editable="bottom" create="0" delete="0">
                                    <field name="partner_link_id" string="Contacto" readonly="1"
                                           context="{'ic_short_name': True}"/>
                                    <field name="parent_id" string="Empresa" optional="hide"
                                           readonly="1"/>
                                    <field name="email" optional="hide" readonly="1"/>
                                    <field name="phone" optional="hide" readonly="1"/>
                                    <field name="allow_personal_consumption" width="175px" readonly="0"
                                           string="Permitir Cons. Personales"
                                           column_invisible="parent.allowed_consumption_types == 'attention_only'"/>
                                    <field name="allow_attention_consumption" width="165px" readonly="0"
                                           string="Permitir Cons. Atención"
                                           column_invisible="parent.allowed_consumption_types == 'personal_only'"/>
                                    <field name="consumption_currency_id" column_invisible="1"/>
                                    <field name="individual_consumed_personal" width="130px" string="Cons. Personal"
                                           widget="monetary" readonly="1"/>
                                    <field name="individual_consumed_attention" width="130px" string="Cons. Atención"
                                           widget="monetary" readonly="1"/>
                                    <field name="available_personal_info" width="115px" string="Disp. Personal"
                                           widget="monetary" readonly="1"
                                           column_invisible="parent.personal_limit == 0"/>
                                    <field name="available_attention_info" width="115px" string="Disp. Atención"
                                           widget="monetary" readonly="1"
                                           column_invisible="parent.attention_limit == 0"/>
                                    <field name="period_end_info" string="Fin Período"
                                           optional="hide" readonly="1"/>
                                </list>
                            </field>
                        </page>

                        <!-- Pestaña Historial de Cambios -->
                        <page string="Historial de Cambios" name="change_log">
                            <field name="log_ids" readonly="1">
                                <list>
                                    <field name="change_date"/>
                                    <field name="user_id"/>
                                    <field name="field_name"/>
                                    <field name="old_value"/>
                                    <field name="new_value"/>
                                    <field name="description"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- VISTA LISTA -->
    <record id="view_internal_consumption_config_list" model="ir.ui.view">
        <field name="name">internal.consumption.config.list</field>
        <field name="model">internal.consumption.config</field>
        <field name="arch" type="xml">
            <list string="Configuraciones de Consumo Interno">
                <field name="name"/>
                <field name="belongs_to_odoo"/>
                <field name="department_id" optional="show"/>
                <field name="partner_id" optional="show"/>
                <field name="personal_limit"/>
                <field name="attention_limit"/>
                <field name="consumed_personal"/>
                <field name="consumed_attention"/>
                <field name="available_personal" optional="hide"/>
                <field name="available_attention" optional="hide"/>
                <field name="personal_percentage"
                       widget="progressbar" string="% Personal"/>
                <field name="attention_percentage"
                       widget="progressbar" string="% Atención"/>
                <field name="period_type"/>
                <field name="account_code" optional="hide"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- VISTA KANBAN: Dashboard con indicadores semafóricos -->
    <record id="view_internal_consumption_config_kanban" model="ir.ui.view">
        <field name="name">internal.consumption.config.kanban</field>
        <field name="model">internal.consumption.config</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_dashboard">
                <field name="name"/>
                <field name="belongs_to_odoo"/>
                <field name="department_id"/>
                <field name="partner_id"/>
                <field name="personal_limit"/>
                <field name="attention_limit"/>
                <field name="consumed_personal"/>
                <field name="consumed_attention"/>
                <field name="available_personal"/>
                <field name="available_attention"/>
                <field name="personal_percentage"/>
                <field name="attention_percentage"/>
                <field name="currency_id"/>
                <field name="period_type"/>
                <field name="period_start"/>
                <field name="period_end"/>
                <field name="audit_count"/>
                <field name="allowed_consumption_types"/>
                    <t t-name="card">
                        <div class="oe_kanban_global_click p-0 mb-0">
                            <!-- Sección Superior -->
                            <div class="px-3 pt-3 pb-1">
                                <!-- Título -->
                                <div class="mb-2">
                                    <strong class="o_kanban_record_title fs-5 d-block" 
                                            style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis; line-height: 1.3;">
                                        <field name="name"/>
                                    </strong>
                                </div>

                                <!-- Subtítulo y Badge -->
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="d-flex align-items-center me-2 text-muted overflow-hidden">
                                        <i class="fa fa-building-o me-1 flex-shrink-0" t-if="record.belongs_to_odoo.raw_value" title="Departamento"/>
                                        <i class="fa fa-user me-1 flex-shrink-0" t-else="" title="Contacto"/>
                                        <span class="text-truncate">
                                            <field name="department_id" t-if="record.belongs_to_odoo.raw_value"/>
                                            <field name="partner_id" t-else=""/>
                                        </span>
                                    </div>
                                    <span t-if="record.belongs_to_odoo.raw_value" class="badge rounded-pill text-bg-primary flex-shrink-0">Departamento</span>
                                    <span t-else="" class="badge rounded-pill text-bg-info flex-shrink-0">Empresa</span>
                                </div>

                            <!-- Hero: Disponible -->
                                <div class="row g-0 text-center mb-3">
                                    <div t-att-class="record.allowed_consumption_types.raw_value === 'attention_only' ? 'd-none' : (record.allowed_consumption_types.raw_value === 'personal_only' ? 'col-12' : 'col-6')">
                                        <div class="text-muted text-uppercase" style="font-size: 0.85rem;">Personal</div>
                                        <div class="fs-4 fw-bold" t-att-class="record.personal_limit.raw_value == 0 ? 'text-success' : (record.available_personal.raw_value &lt;= 0 ? 'text-danger' : 'text-primary')">
                                            <t t-if="record.personal_limit.raw_value == 0">Sin Límite</t>
                                            <t t-else=""><field name="available_personal" widget="monetary"/></t>
                                        </div>
                                    </div>
                                    <div t-att-class="record.allowed_consumption_types.raw_value === 'personal_only' ? 'd-none' : (record.allowed_consumption_types.raw_value === 'attention_only' ? 'col-12' : 'col-6')">
                                        <div class="text-muted text-uppercase" style="font-size: 0.85rem;">Atención</div>
                                        <div class="fs-4 fw-bold" t-att-class="record.attention_limit.raw_value == 0 ? 'text-success' : (record.available_attention.raw_value &lt;= 0 ? 'text-danger' : 'text-primary')">
                                            <t t-if="record.attention_limit.raw_value == 0">Sin Límite</t>
                                            <t t-else=""><field name="available_attention" widget="monetary"/></t>
                                        </div>
                                    </div>
                                </div>

                            </div>

                            <!-- Métricas Secundarias (solo para tipo único) -->
                            <t t-if="record.allowed_consumption_types.raw_value === 'personal_only'">
                                <div class="row g-0 text-center mb-4 mx-3 border-top border-bottom py-2" style="font-size: 0.85rem;">
                                    <div class="col-6 border-end">
                                        <div class="text-muted">Consumido</div>
                                        <strong class="text-dark"><field name="consumed_personal" widget="monetary"/></strong>
                                    </div>
                                    <div class="col-6">
                                        <div class="text-muted">Límite</div>
                                        <strong class="text-dark">
                                            <t t-if="record.personal_limit.raw_value == 0">Sin Límite</t>
                                            <t t-else=""><field name="personal_limit" widget="monetary"/></t>
                                        </strong>
                                    </div>
                                </div>
                            </t>
                            <t t-if="record.allowed_consumption_types.raw_value === 'attention_only'">
                                <div class="row g-0 text-center mb-4 mx-3 border-top border-bottom py-2" style="font-size: 0.85rem;">
                                    <div class="col-6 border-end">
                                        <div class="text-muted">Consumido</div>
                                        <strong class="text-dark"><field name="consumed_attention" widget="monetary"/></strong>
                                    </div>
                                    <div class="col-6">
                                        <div class="text-muted">Límite</div>
                                        <strong class="text-dark">
                                            <t t-if="record.attention_limit.raw_value == 0">Sin Límite</t>
                                            <t t-else=""><field name="attention_limit" widget="monetary"/></t>
                                        </strong>
                                    </div>
                                </div>
                            </t>

                            <!-- Barras de Progreso con consumido/límite -->
                            <div class="w-100 px-3 py-2">
                                <!-- Personal -->
                                <t t-if="record.allowed_consumption_types.raw_value !== 'attention_only'">
                                    <div class="text-muted mb-1" style="font-size: 0.85rem;">Personal</div>
                                    <field name="personal_percentage" widget="internal_consumption_progressbar" 
                                        options="{'current_value': 'personal_percentage', 'max_value': 100, 'editable': false, 'consumed_field': 'consumed_personal', 'limit_field': 'personal_limit'}" 
                                        class="w-100"/>
                                </t>

                                <!-- Atención -->
                                <t t-if="record.allowed_consumption_types.raw_value !== 'personal_only'">
                                    <div t-att-class="record.allowed_consumption_types.raw_value === 'attention_only' ? 'text-muted mb-1' : 'text-muted mb-1 mt-2'" style="font-size: 0.85rem;">Atención</div>
                                    <field name="attention_percentage" widget="internal_consumption_progressbar" 
                                        options="{'current_value': 'attention_percentage', 'max_value': 100, 'editable': false, 'consumed_field': 'consumed_attention', 'limit_field': 'attention_limit'}" 
                                        class="w-100"/>
                                </t>
                            </div>

                            <!-- Footer -->
                            <div class="px-3 pb-3 pt-1">
                                <div class="d-flex justify-content-center align-items-center text-muted mb-2 w-100" style="font-size: 0.85rem;">
                                    <i class="fa fa-calendar me-2" title="Periodo"/>
                                    <span class="text-nowrap"><field name="period_start" options='{"date_only": true}'/></span>
                                    <i class="fa fa-long-arrow-right mx-2 text-muted" title="Hasta"/>
                                    <span class="text-nowrap"><field name="period_end" options='{"date_only": true}'/></span>
                                </div>
                                <div class="text-center border-top pt-2">
                                    <span class="badge text-bg-light border text-dark" style="font-size: 0.8rem;">
                                        <field name="audit_count"/> Consumos Emitidos
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
            </kanban>
        </field>
    </record>

    <!-- VISTA SEARCH -->
    <record id="view_internal_consumption_config_search" model="ir.ui.view">
        <field name="name">internal.consumption.config.search</field>
        <field name="model">internal.consumption.config</field>
        <field name="arch" type="xml">
            <search string="Buscar Configuraciones">
                <field name="name"/>
                <field name="department_id"/>
                <field name="partner_id"/>
                <field name="account_code"/>
                <filter name="filter_odoo"
                        string="Departamentos"
                        domain="[('belongs_to_odoo', '=', True)]"/>
                <filter name="filter_external"
                        string="Contactos Externos"
                        domain="[('belongs_to_odoo', '=', False)]"/>
                <separator/>
                <filter name="filter_active"
                        string="Activos"
                        domain="[('active', '=', True)]"/>
                <filter name="filter_archived"
                        string="Archivados"
                        domain="[('active', '=', False)]"/>

                <group>
                    <filter name="group_department"
                            string="Departamento"
                            context="{'group_by': 'department_id'}"/>
                    <filter name="group_period"
                            string="Tipo de Período"
                            context="{'group_by': 'period_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- VISTA GRAPH: Tendencia de consumo -->
    <record id="view_internal_consumption_config_graph" model="ir.ui.view">
        <field name="name">internal.consumption.config.graph</field>
        <field name="model">internal.consumption.config</field>
        <field name="arch" type="xml">
            <graph string="Análisis de Consumo Interno" type="bar">
                <field name="name"/>
                <field name="personal_limit" type="measure"/>
                <field name="attention_limit" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ACCIÓN DE VENTANA -->
    <record id="action_internal_consumption_config" model="ir.actions.act_window">
        <field name="name">Consumos Internos</field>
        <field name="res_model">internal.consumption.config</field>
        <field name="view_mode">kanban,list,form,graph</field>
        <field name="search_view_id" ref="view_internal_consumption_config_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                ¡Cree su primera configuración de consumo interno!
            </p>
            <p>
                Configure límites de consumo por departamento o contacto externo
                para controlar los gastos internos de su organización.
            </p>
        </field>
    </record>
</odoo>
