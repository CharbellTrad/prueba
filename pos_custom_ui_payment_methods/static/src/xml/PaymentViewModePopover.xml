<?xml version="1.0" encoding="UTF-8"?>
<templates id="pos_custom_ui_payment_methods_templates">

    <!-- Popover template for selecting view modes -->
    <t t-name="pos_custom_ui_payment_methods.PaymentViewModePopover">
        <div class="pm-view-popover">
            <div class="pm-view-popover-header">
                <i class="fa fa-eye me-1" />Modo de Vista
            </div>
            <div class="pm-view-popover-list">
                <t t-foreach="viewModes" t-as="mode" t-key="mode.id">
                    <button class="pm-view-popover-item"
                        t-att-class="{ 'active': mode.id === props.currentMode }"
                        t-on-click="() => this.selectMode(mode.id)">
                        <i t-attf-class="fa {{ mode.icon }} pm-view-popover-icon" />
                        <div class="pm-view-popover-text">
                            <span class="pm-view-popover-label" t-esc="mode.label" />
                            <span class="pm-view-popover-desc" t-esc="mode.description" />
                        </div>
                        <i t-if="mode.id === props.currentMode" class="fa fa-check pm-view-popover-check" />
                    </button>
                </t>
            </div>

            <!-- Scroll toggle -->
            <div class="pm-view-popover-divider" />
            <div class="pm-view-scroll-toggle" t-on-click="toggleScroll">
                <div class="pm-view-scroll-info">
                    <i class="fa fa-arrows-v pm-view-popover-icon" />
                    <div class="pm-view-popover-text">
                        <span class="pm-view-popover-label">Scroll</span>
                        <span class="pm-view-popover-desc">Habilitar scroll en métodos</span>
                    </div>
                </div>
                <div class="pm-view-switch" t-att-class="{ 'active': state.scrollEnabled }">
                    <div class="pm-view-switch-knob" />
                </div>
            </div>
        </div>
    </t>

</templates>
