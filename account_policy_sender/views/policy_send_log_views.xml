<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================== -->
    <!--                     POLICY SEND LOG – LIST VIEW                     -->
    <!-- ================================================================== -->
    <record id="policy_send_log_view_list" model="ir.ui.view">
        <field name="name">policy.send.log.list</field>
        <field name="model">policy.send.log</field>
        <field name="arch" type="xml">
            <list string="Historial de Envíos"
                  decoration-success="status == 'success'"
                  decoration-danger="status == 'error'"
                  decoration-warning="status == 'partial'"
                  create="false">
                <field name="policy_date" string="Fecha póliza"/>
                <field name="send_date" string="Fecha envío"/>
                <field name="company_id"/>
                <field name="move_count" string="Asientos"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'success'"
                       decoration-danger="status == 'error'"
                       decoration-warning="status == 'partial'"/>
                <field name="http_status_code" string="HTTP"/>
                <field name="is_automatic" widget="boolean" string="Automático"/>
                <field name="sent_by" string="Enviado por"/>
            </list>
        </field>
    </record>

    <!-- ================================================================== -->
    <!--                     POLICY SEND LOG – FORM VIEW                    -->
    <!-- ================================================================== -->
    <record id="policy_send_log_view_form" model="ir.ui.view">
        <field name="name">policy.send.log.form</field>
        <field name="model">policy.send.log</field>
        <field name="arch" type="xml">
            <form string="Detalle de Envío" create="false" edit="false">
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="error,partial,success"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Información General">
                            <field name="policy_date" string="Fecha de póliza"/>
                            <field name="send_date" string="Fecha de envío"/>
                            <field name="company_id"/>
                            <field name="move_ids" widget="many2many_tags"
                                   string="Asientos contables"/>
                            <field name="sent_by"/>
                            <field name="is_automatic"/>
                        </group>
                        <group string="Resultado">
                            <field name="http_status_code" string="Código HTTP"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Apuntes Contables" name="move_lines">
                            <group>
                                <group>
                                    <field name="total_debit" string="Total Débitos" widget="monetary"/>
                                    <field name="total_credit" string="Total Créditos" widget="monetary"/>
                                </group>
                                <group>
                                    <field name="total_debit_sent" string="Débitos Enviados" widget="monetary"/>
                                    <field name="total_credit_sent" string="Créditos Enviados" widget="monetary"/>
                                </group>
                            </group>
                            <field name="move_line_ids" readonly="1" nolabel="1">
                                <list editable="bottom"
                                      decoration-success="policy_studio_filled"
                                      decoration-danger="not policy_studio_filled">
                                    <field name="policy_studio_filled" string="Enviado"
                                           width="60px" widget="boolean" nolabel="0"/>
                                    <field name="move_id" string="Asiento"/>
                                    <field name="journal_id" string="Diario"/>
                                    <field name="account_id" string="Cuenta"/>
                                    <field name="product_id" string="Producto"/>
                                    <field name="debit" string="Débito"/>
                                    <field name="credit" string="Crédito"/>
                                </list>
                            </field>
                        </page>
                        <page string="Payload JSON" name="payload">
                            <field name="request_payload" widget="text"
                                   readonly="1" nolabel="1"/>
                        </page>
                        <page string="Respuesta del Endpoint" name="response">
                            <field name="response_body" widget="text"
                                   readonly="1" nolabel="1"/>
                        </page>
                        <page string="Errores" name="errors"
                              invisible="not error_message and not skipped_lines_info">
                            <div invisible="not skipped_lines_info">
                                <h3>Líneas excluidas del envío</h3>
                                <separator/>
                                <field name="skipped_lines_info" widget="text"
                                       readonly="1" nolabel="1"/>
                            </div>
                            <div invisible="not error_message" class="mt-3">
                                <h3>Errores de envío</h3>
                                <separator/>
                                <field name="error_message" widget="text"
                                       readonly="1" nolabel="1"/>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================== -->
    <!--          POLICY SEND LOG – SEARCH VIEW                             -->
    <!-- ================================================================== -->
    <record id="policy_send_log_view_search" model="ir.ui.view">
        <field name="name">policy.send.log.search</field>
        <field name="model">policy.send.log</field>
        <field name="arch" type="xml">
            <search string="Buscar Envíos">
                <field name="company_id"/>
                <field name="sent_by"/>
                <filter name="filter_success" string="Exitosos"
                        domain="[('status', '=', 'success')]"/>
                <filter name="filter_partial" string="Parciales"
                        domain="[('status', '=', 'partial')]"/>
                <filter name="filter_error" string="Errores"
                        domain="[('status', '=', 'error')]"/>
                <separator/>
                <filter name="filter_my_companies" string="Mis Empresas"
                        domain="[('company_id', 'in', allowed_company_ids)]"/>
                <separator/>
                <filter name="filter_automatic" string="Automáticos"
                        domain="[('is_automatic', '=', True)]"/>
                <filter name="filter_manual" string="Manuales"
                        domain="[('is_automatic', '=', False)]"/>
                <group>
                    <filter name="group_by_company" string="Compañía"
                            context="{'group_by': 'company_id'}"/>
                    <filter name="group_by_status" string="Estado"
                            context="{'group_by': 'status'}"/>
                    <filter name="group_by_policy_date" string="Fecha de póliza"
                            context="{'group_by': 'policy_date'}"/>
                    <filter name="group_by_send_date" string="Fecha de envío"
                            context="{'group_by': 'send_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================== -->
    <!--                     ACTION & MENU                                  -->
    <!-- ================================================================== -->
    <record id="action_policy_send_log" model="ir.actions.act_window">
        <field name="name">Historial de Envíos de Pólizas</field>
        <field name="res_model">policy.send.log</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="search_view_id" ref="policy_send_log_view_search"/>
        <field name="context">{'create': False, 'search_default_filter_my_companies': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay registros de envío de pólizas
            </p>
            <p>
                Los registros aparecerán aquí cuando se envíen pólizas
                al sistema externo, ya sea de forma manual o automática.
            </p>
        </field>
    </record>

    <!-- Submenu: Reportes > Pólizas -->
    <menuitem id="menu_policy_reports"
              name="Pólizas"
              parent="account.menu_finance_reports"
              sequence="1"
              groups="account.group_account_manager"/>

    <!-- Submenu: Reportes > Pólizas > Historial de Envíos -->
    <menuitem id="menu_policy_send_log"
              name="Historial de Envíos"
              parent="menu_policy_reports"
              action="action_policy_send_log"
              sequence="10"
              groups="account.group_account_manager"/>
</odoo>
