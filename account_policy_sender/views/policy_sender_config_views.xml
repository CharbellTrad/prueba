<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================== -->
    <!--     POLICY SENDER CONFIG – COMPANY CONFIG FORM (dialog)            -->
    <!-- ================================================================== -->
    <record id="policy_sender_config_company_form" model="ir.ui.view">
        <field name="name">policy.sender.config.company.form</field>
        <field name="model">policy.sender.config</field>
        <field name="arch" type="xml">
            <form string="Configuración por Empresa">
                <sheet>
                    <group>
                        <field name="company_config_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="company_id"/>
                                <field name="segmento"/>
                                <field name="sucursal" string="Sucursal"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <footer>
                    <button string="Guardar" type="object"
                            name="action_save_and_close"
                            class="btn-primary"/>
                    <button string="Cerrar" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ================================================================== -->
    <!--     POLICY SENDER CONFIG – JOURNAL CONDITIONS FORM (dialog)        -->
    <!-- ================================================================== -->
    <record id="policy_sender_config_journal_form" model="ir.ui.view">
        <field name="name">policy.sender.config.journal.form</field>
        <field name="model">policy.sender.config</field>
        <field name="arch" type="xml">
            <form string="Condiciones por Diario">
                <sheet>
                    <group>
                        <field name="journal_condition_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="journal_id"/>
                                <field name="company_name_override" string="Nombre Empresa"/>
                                <field name="segmento"/>
                                <field name="sucursal" string="Sucursal"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <footer>
                    <button string="Guardar" type="object"
                            name="action_save_and_close"
                            class="btn-primary"/>
                    <button string="Cerrar" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
