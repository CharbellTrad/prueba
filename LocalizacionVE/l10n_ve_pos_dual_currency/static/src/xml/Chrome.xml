<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

	<t t-inherit="point_of_sale.Chrome" t-inherit-mode="extension">
		<xpath expr="//div[@class='status-buttons']/CashierName" position="before">
			<div class="oe_status" style="font-size: 18px;">
				<span title="Tasa de Cambio">
					Tasa: <t t-esc="rate"/>
				</span>
			</div>
		</xpath>
	</t>

</templates>