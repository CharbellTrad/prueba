<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<!-- Vista de lista de precios: añade campo tasa de cambio -->
	<record id="product_pricelist_form_dual_currency" model="ir.ui.view">
		<field name="name">product.pricelist.form.dual.currency</field>
		<field name="model">product.pricelist</field>
		<field name="inherit_id" ref="product.product_pricelist_view"/>
		<field name="arch" type="xml">
			<xpath expr="//field[@name='currency_id']" position="after">
				<field name="currency_ref_id" invisible="1"/>
				<field name="currency_id" invisible="1"/>
				<field name="currency_rate_ref"
					domain="[('currency_id', '=', currency_ref_id)]"
					widget="many2one"
					options="{'no_create': True}"/>
			</xpath>
		</field>
	</record>

	<!-- Vista de configuración POS: toggle tasa inversa -->
	<record id="pos_config_view_form_dual_currency" model="ir.ui.view">
		<field name="name">pos.config.form.dual.currency</field>
		<field name="model">pos.config</field>
		<field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
		<field name="arch" type="xml">
			<xpath expr="//div[@id='other_devices']" position="after">
				<div class="col-12 col-lg-6 o_setting_box" id="dual_currency_settings">
					<div class="o_setting_left_pane">
						<field name="rate_display_inverse"/>
					</div>
					<div class="o_setting_right_pane">
						<label for="rate_display_inverse"/>
						<div class="text-muted">
							Muestra la tasa como Bs/$ (ej: 38.00) en vez de $/Bs (ej: 0.0263)
						</div>
					</div>
				</div>
			</xpath>
		</field>
	</record>
</odoo>
