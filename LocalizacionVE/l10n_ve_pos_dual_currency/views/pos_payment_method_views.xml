<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="pos_payment_method_view_form" model="ir.ui.view">
		<field name="name">pos.payment.method.form</field>
		<field name="model">pos.payment.method</field>
		<field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
		<field name="arch" type="xml">
			<!-- Ocultar el diario nativo — el POS usará el transitorio automáticamente -->
			<field name="journal_id" position="attributes">
				<attribute name="invisible">1</attribute>
				<attribute name="required">0</attribute>
			</field>
			<!-- Insertar campos duales después del journal_id nativo -->
			<field name="journal_id" position="after">
				<field name="company_id" invisible="1"/>
				<field name="currency_id" options="{'no_create': 1}"/>
				<field name="real_journal_id"
				       domain="[('type', 'in', ('cash', 'bank')), ('company_id', '=', company_id)]"
				       options="{'no_create': 1}"
				       required="1"/>
				<field name="transit_journal_id" readonly="1"
				       attrs="{'invisible': [('transit_journal_id', '=', False)]}"/>
			</field>
		</field>
	</record>
</odoo>