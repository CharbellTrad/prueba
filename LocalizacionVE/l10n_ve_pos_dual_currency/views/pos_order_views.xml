<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_pos_form_dual_currency" model="ir.ui.view">
        <field name="name">pos.order.form.dual.currency</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='session_id']" position="after">
                <field name="currency_rate_ref" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_pos_order_tree_dual_currency" model="ir.ui.view">
        <field name="name">pos.order.tree.dual.currency</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='session_id']" position="after">
                <field name="currency_rate_ref" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
