<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">

	<t t-name="PaymentScreenStatus" t-inherit="point_of_sale.PaymentScreenStatus" t-inherit-mode="extension" owl="1">
		<xpath expr="//div[hasclass('payment-status-total-due')]" position="before">
			<div t-if="apply_igtf" class="payment-status-total-due">
				<span class="label">IGTF</span>
				<span>
					<t t-esc="IGTFText"/>
				</span>
			</div>
		</xpath>
	</t>

</templates>