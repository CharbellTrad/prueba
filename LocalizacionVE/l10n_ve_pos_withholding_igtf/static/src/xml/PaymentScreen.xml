<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">

	<t t-name="PaymentScreen" t-inherit="point_of_sale.PaymentScreen" t-inherit-mode="extension" owl="1">
		<xpath expr="//div[hasclass('validation')]" position="attributes">
			<attribute name="t-if">!env.isMobile &amp;&amp; is_igtf_paid</attribute>
		</xpath>
		<xpath expr="//div[hasclass('validation')]" position="after">
			<div t-if="!is_igtf_paid" class="button next validation highlight" t-on-click="() => this.trigger('pay-igtf')">
				<div class="pay-circle">
					<i class="fa fa-chevron-right" role="img" aria-label="PayIGTF" title="PayIGTF" />
				</div>
				<span class="next_text">Pagar IGTF</span>
			</div>
		</xpath>
	</t>

</templates>