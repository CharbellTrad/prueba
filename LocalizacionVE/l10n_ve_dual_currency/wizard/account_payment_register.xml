<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<record id="view_account_payment_register_form" model="ir.ui.view">
		<field name="name">account.payment.register.form</field>
		<field name="model">account.payment.register</field>
		<field name="inherit_id" ref="account.view_account_payment_register_form"/>
		<field name="arch" type="xml">
			<xpath expr="//label[@for='amount']" position="before">
				<field name="currency_ref_id" invisible="1"/>
				<field name="currency_rate_ref" options="{'no_create': 1, 'no_open': 1}"/>
				<field name="show_amount_in_source" invisible="1"/>
				<field name="source_currency_id" invisible="1"/>
				<field name="amount_in_source_currency" attrs="{'invisible': [('show_amount_in_source', '=', False)]}"/>
			</xpath>
			<xpath expr="//field[@name='journal_id']" position="attributes">
				<attribute name="domain">[('type', 'in', ('bank', 'cash')), ('company_id', '=', company_id), ('currency_id', '!=', False)]</attribute>
			</xpath>
		</field>
	</record>
</odoo>