<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- account.bank.statement.line tree inside Bank Reconciliation Widget
         Only one rate field: rate_id (used by our override to compute company amount).
         The old currency_rate_ref still exists on the account.move level and gets propagated
         automatically when rate_id is set. -->
    <record id="view_bank_statement_line_tree_bank_rec_widget_inherit" model="ir.ui.view">
        <field name="name">account.bank.statement.line.tree.bank_rec_widget.inherit</field>
        <field name="model">account.bank.statement.line</field>
        <field name="inherit_id" ref="account_accountant.view_bank_statement_line_tree_bank_rec_widget"/>
        <field name="arch" type="xml">
            <field name="foreign_currency_id" position="after">
                <field name="currency_ref_id" invisible="1"/>
                <field name="is_operative_currency_journal" invisible="1"/>
                <field name="rate_id"
                       string="Tasa de cambio op."
                       optional="show"
                       domain="[('currency_id', '=', currency_ref_id)]"
                       options="{'no_create': True, 'no_open': True}"
                       attrs="{'readonly': [('is_reconciled', '=', True)], 'invisible': [('is_operative_currency_journal', '=', False)]}"/>
            </field>
        </field>
    </record>

    <!-- account.bank.statement.line form inside Bank Reconciliation popup -->
    <record id="view_bank_statement_line_form_bank_rec_widget_inherit" model="ir.ui.view">
        <field name="name">account.bank.statement.line.form.bank_rec_widget.inherit</field>
        <field name="model">account.bank.statement.line</field>
        <field name="inherit_id" ref="account_accountant.view_bank_statement_line_form_bank_rec_widget"/>
        <field name="arch" type="xml">
            <field name="foreign_currency_id" position="after">
                <field name="currency_ref_id" invisible="1"/>
                <field name="is_operative_currency_journal" invisible="1"/>
                <field name="rate_id"
                       string="Tasa de cambio op."
                       domain="[('currency_id', '=', currency_ref_id)]"
                       options="{'no_create': True, 'no_open': True}"
                       attrs="{'readonly': [('is_reconciled', '=', True)], 'invisible': [('is_operative_currency_journal', '=', False)]}"/>
            </field>
        </field>
    </record>

    <!-- Kanban view: inject rate_id so the server returns updated balance after rate change -->
    <record id="view_bank_statement_line_kanban_bank_rec_widget_inherit" model="ir.ui.view">
        <field name="name">account.bank.statement.line.kanban.bank_rec_widget.inherit</field>
        <field name="model">account.bank.statement.line</field>
        <field name="inherit_id" ref="account_accountant.view_bank_statement_line_kanban_bank_rec_widget"/>
        <field name="arch" type="xml">
            <field name="foreign_currency_id" position="after">
                <field name="rate_id" invisible="1"/>
            </field>
        </field>
    </record>
</odoo>
