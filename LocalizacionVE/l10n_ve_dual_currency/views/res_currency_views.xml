<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<record id="view_currency_form" model="ir.ui.view">
		<field name="name">res.currency.form</field>
		<field name="model">res.currency</field>
		<field name="inherit_id" ref="base.view_currency_form"/>
		<field name="arch" type="xml">
			<xpath expr="//sheet" position="before">
                <header>
                    <button name="action_get_tax_BCV" icon="fa-refresh" string="Agregar Tasa BCV" type="object" />
                    <button name="action_update_prices" icon="fa-usd" string="Actualizar Precios" type="object" class = "btn-primary"/>
                </header>
            </xpath>
			<xpath expr="//field[@name='rate_ids']/tree" position="inside">
				<field name="concept" placeholder="Paralelo..."/>
				<field name="is_bcv_rate"/>
			</xpath>
		</field>
	</record>
</odoo>