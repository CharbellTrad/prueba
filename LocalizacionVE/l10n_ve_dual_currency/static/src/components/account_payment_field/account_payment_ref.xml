<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-inherit="account.AccountPaymentField" t-inherit-mode="extension" owl="1">
        <xpath expr="//td[@t-if='!line.is_exchange' and @style='text-align:right;']" position="replace">
            <td t-if="!line.is_exchange" style="text-align:right;">
                <span class="oe_form_field oe_form_field_float oe_form_field_monetary" style="margin-left: -10px;">
                    <t t-esc="line.amount_formatted"/>
                </span>
                <br/>
                <span t-if="line.amount_ref_formatted" class="oe_form_field oe_form_field_float oe_form_field_monetary text-muted" style="margin-left: -10px; font-size: 0.9em;">
                    <t t-esc="line.amount_ref_formatted"/>
                </span>
            </td>
        </xpath>
    </t>

    <t t-inherit="account.AccountPaymentPopOver" t-inherit-mode="extension" owl="1">
        <xpath expr="//table/tr[1]" position="after">
            <tr t-if="props.amount_ref">
                <td><strong>Monto ope.: </strong></td>
                <td>
                    <t t-esc="props.amount_ref_formatted"></t>
                </td>
            </tr>
        </xpath>
    </t>

</templates>
