<?xml version="1.0" encoding="utf-8"?>
<templates>
    <!--
        QWeb template for the TaxTotalsRefComponent.
        Mirrors account.TaxTotalsField but for the operational currency (VES).
        The `totals` dict is built by account.move._compute_tax_totals_ref().
    -->
    <t t-name="l10n_ve_dual_currency.TaxTotalsRefField" owl="1">
        <table t-if="totals" class="oe_right" style="border-top: 1px solid #ced4da; margin-top: 6px;">
            <thead>
                <tr>
                    <th colspan="2"
                        style="font-size:0.85em; padding-bottom:2px; white-space:nowrap; color:#6c757d;">
                        Totales en moneda operativa
                        <t t-if="totals.currency_name">
                            (<t t-out="totals.currency_name"/>)
                        </t>
                    </th>
                </tr>
            </thead>
            <tbody>
                <!-- Subtotals (base imponible) -->
                <t t-foreach="totals.subtotals" t-as="subtotal" t-key="subtotal['name']">
                    <tr>
                        <td class="o_td_label">
                            <label class="o_form_label o_tax_total_label"
                                   t-esc="subtotal['name']"/>
                        </td>
                        <td class="o_list_monetary">
                            <span style="white-space:nowrap; font-weight:bold;"
                                  t-out="subtotal['formatted_amount']"/>
                        </td>
                    </tr>

                    <!-- Tax groups under this subtotal -->
                    <t t-foreach="totals.groups_by_subtotal[subtotal['name']]"
                       t-as="taxGroup" t-key="taxGroup.group_key">
                        <tr>
                            <td class="o_td_label">
                                <label class="o_form_label o_tax_total_label"
                                       t-esc="taxGroup.tax_group_name"/>
                            </td>
                            <td class="o_tax_group">
                                <span class="o_tax_group_amount_value o_list_monetary"
                                      style="white-space:nowrap;"
                                      t-out="taxGroup.formatted_tax_group_amount"/>
                            </td>
                        </tr>
                    </t>
                </t>

                <!-- Grand total -->
                <tr>
                    <td class="o_td_label">
                        <label class="o_form_label o_tax_total_label">Total</label>
                    </td>
                    <td class="o_list_monetary">
                        <span name="amount_total_ref"
                              style="font-size:1.3em; font-weight:bold; white-space:nowrap;"
                              t-out="totals.formatted_amount_total"/>
                    </td>
                </tr>
            </tbody>
        </table>
    </t>
</templates>
