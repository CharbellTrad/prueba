<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_withholding_universal_pay_wizard" model="ir.ui.view">
        <field name="name">account.withholding.universal.pay.wizard.form</field>
        <field name="model">account.withholding.universal.pay.wizard</field>
        <field name="arch" type="xml">
            <form string="Pago Universal de Retenciones">
                <sheet>
                    <group>
                        <group>
                            <field name="journal_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="payment_date"/>
                            <field name="currency_rate_ref" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                        <group>
                            <field name="total_amount" widget="monetary" readonly="1" decoration-bf="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="company_id" invisible="1"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="IVA">
                            <field name="iva_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="subject_id"/>
                                    <field name="date"/>
                                    <field name="amount" sum="Total IVA"/>
                                </tree>
                            </field>
                        </page>
                        <page string="ISLR">
                            <field name="islr_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="subject_id"/>
                                    <field name="date"/>
                                    <field name="amount" sum="Total ISLR"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Municipales">
                            <field name="municipal_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="subject_id"/>
                                    <field name="date"/>
                                    <field name="amount" sum="Total Municipal"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_pay" type="object" string="Registrar Pago" class="btn-primary"/>
                    <button special="cancel" string="Cancelar" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_account_withholding_universal_pay" model="ir.actions.act_window">
        <field name="name">Pago Masivo de Retenciones</field>
        <field name="res_model">account.withholding.universal.pay.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_account_withholding_universal_pay"
              name="Pago Multilateral de Retenciones"
              action="action_account_withholding_universal_pay"
              parent="account.menu_finance_payables"
              sequence="120"/>
</odoo>
