<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_account_withholding_municipal_payment_wizard" model="ir.ui.view">
            <field name="name">account.withholding.municipal.payment.wizard.form</field>
            <field name="model">account.withholding.municipal.payment.wizard</field>
            <field name="arch" type="xml">
                <form string="Pago de Retenciones Municipales">
                    <group>
                        <group>
                            <field name="journal_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="payment_date"/>
                            <field name="currency_rate_ref" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                        <group>
                            <field name="amount" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="amount_to_pay" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Retenciones a Pagar">
                            <field name="withholding_ids" readonly="1" options="{'no_open': True}">
                                <tree>
                                    <field name="name"/>
                                    <field name="subject_id"/>
                                    <field name="date"/>
                                    <field name="amount" sum="Total"/>
                                    <field name="state" invisible="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                    <footer>
                        <button string="Pagar" name="action_pay" type="object" class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_account_withholding_municipal_payment_wizard" model="ir.actions.act_window">
            <field name="name">Pagar Retenciones Municipales</field>
            <field name="res_model">account.withholding.municipal.payment.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_account_withholding_municipal_payment_wizard"/>
            <field name="target">new</field>
            <field name="binding_model_id" ref="l10n_ve_withholding_municipal.model_account_withholding_municipal"/>
            <field name="binding_view_types">list</field>
        </record>
    </data>
</odoo>
