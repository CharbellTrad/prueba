<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<!-- ── Extend account.sale.sequence form view ────────────────────── -->
	<record id="account_sale_sequence_view_form_fiscal_machine" model="ir.ui.view">
		<field name="name">account.sale.sequence.form.fiscal_machine</field>
		<field name="model">account.sale.sequence</field>
		<field name="inherit_id" ref="l10n_ve_sale_sequence.account_sale_sequence_view_form"/>
		<field name="arch" type="xml">

			<!-- Add fiscal_machine page in the notebook -->
			<page name="journal_ids" position="after">
				<page name="fiscal_machine_page" string="Máquinas Fiscales"
					  attrs="{'invisible': [('sequence_type', '!=', 'fiscal_machine')]}">
					<field name="fiscal_machine_ids" nolabel="1">
						<tree editable="bottom" string="Cajas / Máquinas Fiscales">
							<field name="company_id" invisible="1"/>
							<field name="pos_config_id" string="Caja POS"
								   options="{'no_create': 1}"
								   required="1"/>
							<!-- Facturas -->
							<field name="invoice_control_prefix"   string="Pref. Factura"/>
							<field name="invoice_control_number_next" string="Próx. Ctrl. Fact."/>
							<field name="invoice_control_padding"  string="Dígitos Fact." optional="hide"/>
							<!-- Notas de crédito -->
							<field name="refund_control_prefix"    string="Pref. N. Cred."/>
							<field name="refund_control_number_next"  string="Próx. Ctrl. N.Cred."/>
							<field name="refund_control_padding"   string="Dígitos N.Cred." optional="hide"/>
							<!-- Notas de débito -->
							<field name="debit_control_prefix"     string="Pref. N. Déb."/>
							<field name="debit_control_number_next"   string="Próx. Ctrl. N.Déb."/>
							<field name="debit_control_padding"    string="Dígitos N.Déb." optional="hide"/>
							<!-- Hidden sequence ids needed for related fields -->
							<field name="invoice_control_sequence_id" column_invisible="1"/>
							<field name="refund_control_sequence_id"  column_invisible="1"/>
							<field name="debit_control_sequence_id"   column_invisible="1"/>
						</tree>
						<form string="Configuración de Caja / Máquina Fiscal">
							<group>
								<group string="Caja">
									<field name="company_id" invisible="1"/>
									<field name="pos_config_id" options="{'no_create': 1}"/>
								</group>
							</group>
							<group string="Números de Control">
								<group string="Facturas" col="6">
									<field name="invoice_control_sequence_id" invisible="1"/>
									<field name="invoice_control_prefix"   colspan="2"/>
									<field name="invoice_control_number_next" colspan="2"/>
									<field name="invoice_control_padding"  colspan="2"/>
								</group>
								<group string="Notas de Crédito" col="6">
									<field name="refund_control_sequence_id" invisible="1"/>
									<field name="refund_control_prefix"    colspan="2"/>
									<field name="refund_control_number_next"  colspan="2"/>
									<field name="refund_control_padding"   colspan="2"/>
								</group>
								<group string="Notas de Débito" col="6">
									<field name="debit_control_sequence_id" invisible="1"/>
									<field name="debit_control_prefix"     colspan="2"/>
									<field name="debit_control_number_next"   colspan="2"/>
									<field name="debit_control_padding"    colspan="2"/>
								</group>
							</group>
						</form>
					</field>
				</page>
			</page>

			<!-- Hide old "Número de control" group when type is fiscal_machine -->
			<group name="control_number" position="attributes">
				<attribute name="attrs">
					{"invisible": [("sequence_type", "=", "fiscal_machine")]}
				</attribute>
			</group>

		</field>
	</record>

	<!-- ── Extend list view to show fiscal_machine ───────────────────── -->
	<record id="account_sale_sequence_view_tree_fiscal_machine" model="ir.ui.view">
		<field name="name">account.sale.sequence.tree.fiscal_machine</field>
		<field name="model">account.sale.sequence</field>
		<field name="inherit_id" ref="l10n_ve_sale_sequence.account_sale_sequence_view_tree"/>
		<field name="arch" type="xml">
			<field name="serie" position="before">
				<field name="fiscal_machine_ids" string="Cajas" widget="many2many_tags"
					   options="{'color_field': 'id'}"
					   attrs="{'invisible': [('sequence_type', '!=', 'fiscal_machine')]}"/>
			</field>
		</field>
	</record>
</odoo>
