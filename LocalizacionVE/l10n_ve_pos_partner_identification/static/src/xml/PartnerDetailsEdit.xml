<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="PartnerDetailsEdit" t-inherit="point_of_sale.PartnerDetailsEdit" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('partner-details-right')]/div[6]/span" position="replace">
            <span class="label">RIF</span>
        </xpath>
        <xpath expr="//div[hasclass('partner-details-right')]/div[1]" position="replace">
        </xpath>

        <xpath expr="//div[hasclass('partner-details-right')]/div[3]" position="replace">
        </xpath>
        <xpath expr="//div[hasclass('partner-details-right')]/div[3]" position="replace">
        </xpath>
        <xpath expr="//div[hasclass('partner-details-right')]/div[2]" position="replace">
        </xpath>
        <xpath expr="//input[@name='name']" position="after">
            <input class="detail partner-name" name="phone" placeholder="Phone" type="tel" t-model="changes.phone" t-on-change="captureChange" />
            <input class="detail partner-name" name="identification" placeholder="Documento de Identidad" t-model="changes.identification" t-on-change="captureChange" />
        </xpath>

        <xpath expr="//div[hasclass('partner-details-right')]" position="inside">
            <div class="partner-detail">
                <span class="label">Tipo de Contacto</span>
                <select class="detail" name="is_company" t-model="changes.is_company" t-on-change="captureChange">
                    <option value="false">
                        Individual
                    </option>
                    <option value="true">
                        Compañia
                    </option>
                </select>
            </div>
            <div class="partner-detail" t-if="changes.is_company">
                <span class="label">Tipo de Persona</span>
                <select class="detail" name="lang" t-model="changes.person_type_id" t-on-change="captureChange">
                    <t t-foreach="env.pos.person_type_company" t-as="person_type" t-key="person_type.id">
                        <option t-att-value="person_type.id">
                            <t t-esc="person_type.name" />
                        </option>
                    </t>
                </select>
            </div>
            <div class="partner-detail" t-if="!changes.is_company">
                <span class="label">Tipo de Persona</span>
                <select class="detail" name="lang" t-model="changes.person_type_id" t-on-change="captureChange">
                    <t t-foreach="env.pos.person_type_individual" t-as="person_type" t-key="person_type.id">
                        <option t-att-value="person_type.id">
                            <t t-esc="person_type.name" />
                        </option>
                    </t>
                </select>
            </div>
        </xpath>
    </t>
</templates>