<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_withholding_iva_payment_wizard" model="ir.ui.view">
        <field name="name">account.withholding.iva.payment.wizard.form</field>
        <field name="model">account.withholding.iva.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Pagar Retenciones IVA">
                <group>
                    <group>
                        <field name="journal_id" options="{'no_create': True, 'no_open': True}"/>
                        <field name="payment_date"/>
                        <field name="currency_rate_ref" options="{'no_create': True, 'no_open': True}"/>
                    </group>
                    <group>
                        <field name="amount" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        <field name="amount_to_pay" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                </group>
                <notebook>
                    <page string="Retenciones Seleccionadas">
                        <field name="withholding_ids" readonly="1" force_save="1">
                            <tree>
                                <field name="name"/>
                                <field name="subject_id" string="Proveedor"/>
                                <field name="date"/>
                                <field name="amount" sum="Total"/>
                                <field name="state"/>
                            </tree>
                        </field>
                    </page>
                </notebook>
                <footer>
                    <button name="action_pay" string="Pagar" type="object" class="oe_highlight"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Acción para Múltiples Registros -->
    <record id="action_account_withholding_iva_payment_wizard" model="ir.actions.act_window">
        <field name="name">Pagar Retenciones</field>
        <field name="res_model">account.withholding.iva.payment.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="l10n_ve_withholding_iva.model_account_withholding_iva"/>
        <field name="binding_view_types">list</field>
    </record>
</odoo>
