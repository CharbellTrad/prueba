<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="view_pay_igtf_wizard_form" model="ir.ui.view">
		<field name="name">pay.igtf.wizard.form</field>
		<field name="model">pay.igtf.wizard</field>
		<field name="arch" type="xml">
			<form string="Pagar IGTF al SENIAT">
				<group>
					<group>
						<field name="origin_payment_id" invisible="1"/>
						<field name="currency_id" invisible="1"/>
						<field name="company_id" invisible="1"/>
						<field name="currency_rate_ref" invisible="1" force_save="1"/>
						
						<field name="amount_residual" widget="monetary" options="{'currency_field': 'currency_id'}"/>
						<field name="amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
						<field name="journal_id" options="{'no_create': True, 'no_open': True}"/>
					</group>
				</group>
				<footer>
					<button name="action_create_payment" string="Generar Pago" type="object" class="btn-primary" data-hotkey="q"/>
					<button string="Cancelar" class="btn-secondary" special="cancel" data-hotkey="z"/>
				</footer>
			</form>
		</field>
	</record>

	<record id="action_pay_igtf_wizard" model="ir.actions.act_window">
		<field name="name">Pagar IGTF Percibido</field>
		<field name="res_model">pay.igtf.wizard</field>
		<field name="view_mode">form</field>
		<field name="target">new</field>
		<field name="binding_model_id" eval="False"/>
	</record>

	<!-- Add to Accounting > Vendors menu -->
	<menuitem id="menu_pay_igtf_wizard"
			  name="Pago de IGTF al SENIAT"
			  parent="account.menu_finance_payables"
			  action="action_pay_igtf_wizard"
			  sequence="120"/>
</odoo>
