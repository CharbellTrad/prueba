<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<record id="view_account_payment_form" model="ir.ui.view">
		<field name="name">account.payment.form</field>
		<field name="model">account.payment</field>
		<field name="inherit_id" ref="account.view_account_payment_form"/>
		<field name="arch" type="xml">
			<xpath expr="//button[@name='button_open_journal_entry']" position="before">
				<field name="igtf_move_id" invisible="1"/>
				<button name="button_open_igtf_entry" type="object" class="oe_stat_button" icon="fa-bars" attrs="{'invisible': ['|', ('igtf_move_id', '=', False), ('state', '!=', 'posted')]}">
					<div class="o_stat_info">
						<span class="o_stat_text">Asiento IGTF</span>
					</div>
				</button>
			</xpath>
			<xpath expr="//header" position="inside">
				<field name="igtf_payment_state" invisible="1"/>
				<button name="action_pay_manual_igtf" type="object" string="Cobrar / Pagar IGTF" class="oe_highlight" attrs="{'invisible': ['|', '|', '|', ('state', '!=', 'posted'), ('apply_igtf', '=', False), ('calculate_igtf', '=', False), ('igtf_payment_state', '=', 'paid')]}"/>
				<button name="action_pay_seniat_igtf" type="object" string="Pagar IGTF al SENIAT" class="oe_highlight" attrs="{'invisible': ['|', '|', '|', '|', ('payment_type', '!=', 'inbound'), ('state', '!=', 'posted'), ('apply_igtf', '=', False), ('calculate_igtf', '=', False), ('igtf_payment_state', '=', 'not_paid')]}"/>
			</xpath>
			<xpath expr="//sheet" position="inside">
				<widget name="web_ribbon" title="IGTF Pagado" bg_color="bg-success" attrs="{'invisible': [('igtf_payment_state', '!=', 'paid')]}"/>
				<widget name="web_ribbon" title="IGTF Parcial" bg_color="bg-info" attrs="{'invisible': [('igtf_payment_state', '!=', 'partial')]}"/>
			</xpath>
			<xpath expr="//group[@name='group2']" position="inside">
				<field name="apply_igtf" invisible="1"/>
				<label for="calculate_igtf" attrs="{'invisible': [('apply_igtf', '=', False)]}"/>
				<div attrs="{'invisible': [('apply_igtf', '=', False)]}">
					<field name="calculate_igtf"/>
				</div>
				<field name="igtf_amount" attrs="{'invisible': ['|', ('apply_igtf', '=', False), ('calculate_igtf', '=', False)]}"/>
				<field name="igtf_journal_id" attrs="{'invisible': ['|', ('apply_igtf', '=', False), ('calculate_igtf', '=', False)], 'required': [('apply_igtf', '!=', False), ('calculate_igtf', '=', True)]}"/>
				<field name="igtf_origin_payment_id" attrs="{'invisible': [('igtf_origin_payment_id', '=', False)]}" readonly="1"/>
				<field name="igtf_origin_payment_ids" widget="many2many_tags" attrs="{'invisible': [('igtf_origin_payment_ids', '=', [])]}" readonly="1"/>
			</xpath>
		</field>
	</record>
</odoo>