<odoo>
	<record id="res_config_settings_view_form" model="ir.ui.view">
		<field name="name">res.config.settings.view.form.inherit.point_of_sale</field>
		<field name="model">res.config.settings</field>
		<field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
		<field name="arch" type="xml">
			<xpath expr="//div[@id='pos_technical_section']" position="after">
				<h2 name="fiscal_printer">Impresora Fiscal</h2>
				<div class="row mt16 o_settings_container" name="api_url_container">
					<div class="col-12 col-lg-6 o_setting_box" title="active">
						<div class="o_setting_left_pane">
							<field name="active_fiscal_machine"/>
						</div>
						<div class="o_setting_right_pane">
							<label for="active_fiscal_machine"/>
							<div class="text-muted">
								Permite utilizar la impresión fiscal en esta caja.
							</div>
						</div>
					</div>
					<div class="col-12 col-lg-6 o_setting_box" title="url" attrs="{'invisible': [('active_fiscal_machine', '=', False)]}">
						<div class="o_setting_right_pane">
							<label for="fiscal_url_api"/>
							<div class="text-muted">
								Ej. http://localhost:8001/printer
							</div>
							<div class="content-group mt16">
								<field name="fiscal_url_api" attrs="{'required': [('active_fiscal_machine', '=', True)]}"/>
							</div>
						</div>
					</div>
				</div>
			</xpath>
		</field>
	</record>
</odoo>