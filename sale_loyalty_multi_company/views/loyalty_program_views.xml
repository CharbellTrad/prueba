<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="loyalty_program_view_form_inherit_multi_company" model="ir.ui.view">
        <field name="name">loyalty.program.view.form.inherit.multi.company</field>
        <field name="model">loyalty.program</field>
        <field name="inherit_id" ref="loyalty.loyalty_program_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id'][2]" position="attributes">
                <attribute name="string">Empresa Principal</attribute>
            </xpath>
            <xpath expr="//field[@name='company_id'][2]" position="after">
                <field name="multi_company_ids" widget="many2many_tags" groups="base.group_multi_company"/>
            </xpath>
        </field>
    </record>

    <record id="loyalty_program_view_tree_inherit_multi_company" model="ir.ui.view">
        <field name="name">loyalty.program.view.tree.inherit.multi.company</field>
        <field name="model">loyalty.program</field>
        <field name="inherit_id" ref="loyalty.loyalty_program_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id']" position="attributes">
                <attribute name="string">Empresa Principal</attribute>
            </xpath>
            <field name="company_id" position="after">
                <field name="multi_company_ids" widget="many2many_tags" groups="base.group_multi_company" optional="show"/>
            </field>
        </field>
    </record>
</odoo>
