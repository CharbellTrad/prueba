<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tarjeta de lealtad: campos eWallet en formulario -->
    <record id="loyalty_card_view_form_ewallet" model="ir.ui.view">
        <field name="name">loyalty.card.form.ewallet</field>
        <field name="model">loyalty.card</field>
        <field name="inherit_id" ref="loyalty.loyalty_card_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="wallet_type" readonly="1"
                       invisible="not program_id or program_type != 'ewallet'"/>
                <field name="wallet_active"
                       invisible="not program_id or program_type != 'ewallet'"/>
                <field name="wallet_pin_set" readonly="1"
                       invisible="not program_id or program_type != 'ewallet'"/>
            </xpath>
        </field>
    </record>

    <!-- Tarjeta de lealtad: columnas eWallet en lista -->
    <record id="loyalty_card_view_tree_ewallet" model="ir.ui.view">
        <field name="name">loyalty.card.list.ewallet</field>
        <field name="model">loyalty.card</field>
        <field name="inherit_id" ref="loyalty.loyalty_card_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="wallet_type" optional="show"
                       invisible="program_type != 'ewallet'"/>
                <field name="wallet_active" optional="show"
                       invisible="program_type != 'ewallet'"
                       widget="boolean_toggle"/>
            </xpath>
        </field>
    </record>
</odoo>